        "type": "code",
        "name": "Prepara prompt",
        "position": {
          "x": 720,
          "y": 0
        },
        "parameters": {
          "code": "const ms = items.filter(x => x && x.title); const blob = ms.map(x => 'Meeting: ' + x.title + '\\nTrascrizione: ' + String(x.transcript || '').slice(0, 4000)).join('\\n\\n---\\n\\n'); return [{ prompt: 'Riassumi in italiano questi meeting, con punti chiave e action item per ciascuno:\\n\\n' + (blob || 'Nessun meeting recente da riassumere.') }];"
        }
      },
